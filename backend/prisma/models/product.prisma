model Products {
    id                 String             @id @default(cuid())
    sl                 Int                @default(autoincrement())
    name               String
    description        String
    price              Int
    offer              Int
    rating             Decimal
    stock              Int
    brand              String
    category           String
    imageURL           String?
    cloudinaryPublicId String?
    createdAt          DateTime           @default(now())
    updatedAt          DateTime           @updatedAt
    transactionItems   TransactionItems[]

    @@map("products")
}
