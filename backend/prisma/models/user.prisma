model User {
    id             String        @id @default(cuid())
    name           String
    role           Role          @default(SELF)
    email          String        @unique
    emailVerified  Boolean       @default(false)
    profilePhoto   String?
    profilePhotoId String?
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @updatedAt
    transactions   Transaction[]

    //Relations
    profile  Profile?
    sessions Session[]
    accounts Account[]

    @@map(name: "user")
}

model Profile {
    id        String   @id @default(cuid())
    userId    String   @unique
    firstName String?
    lastName  String?
    age       Int?
    phone     String
    address   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
    id                   String    @id @default(cuid())
    userId               String
    accountId            String
    providerId           String?
    accessToken          String?
    refreshToken         String?
    accessTokenExpiresAt DateTime?
    password             String?
    createdAt            DateTime  @default(now())
    updatedAt            DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, providerId, accountId])
    @@map("account")
}

model Session {
    id        String   @id @default(cuid())
    userId    String
    token     String   @unique
    expiresAt DateTime
    ipAddress String?
    userAgent String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("session")
}
